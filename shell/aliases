# Shared aliases — sourced by both zsh and bash

# Modern CLI replacements
alias l='eza -lhga --icons --group-directories-first'
alias ls='eza --icons --group-directories-first'
alias tree='eza --tree --icons'
if command -v batcat &>/dev/null; then
    alias cat='batcat --plain'
elif command -v bat &>/dev/null; then
    alias cat='bat --plain'
fi
alias grep='grep --color=auto'

# Whole-system backup with interactive rsync progress.
backup() {
    [ "$#" -gt 0 ] || set -- --progress
    sudo bash -lc 'set -a; . /etc/pi-backup.conf; set +a; exec /usr/local/sbin/pi-backup-drive run "$@"' backup "$@"
}

# Python
alias python='python3'
alias pip='pip3'
alias venv='source venv/bin/activate'

# File manager
y() {
	local tmp="$(mktemp -t "yazi-cwd.XXXXXX")" cwd
	command yazi "$@" --cwd-file="$tmp"
	IFS= read -r cwd < "$tmp"
	[ -n "$cwd" ] && [ "$cwd" != "$PWD" ] && [ -d "$cwd" ] && builtin cd -- "$cwd"
	rm -f -- "$tmp"
}

# OpenCode - PATH is set in shell/profile; no alias needed

# tmux launchers.
# `t` starts/attaches plain full-screen tmux on session `main`.
#   -A attach-or-create; multiple clients may stay attached.
# For iTerm2 control mode (-CC) on purpose, run: TMUX_CONTROL_MODE=1 t
t() {
    [ -n "${DISPLAY:-}" ] && tmux set-environment -g DISPLAY "$DISPLAY" 2>/dev/null
    if [ "${TMUX_CONTROL_MODE:-}" = "1" ]; then
        tmux -CC new-session -A -s main
    else
        tmux new-session -A -s main
    fi
}
alias tmx='tmux new-session \; split-window -h -p 67 \; select-pane -t 0'

# nchat — separate config dirs per protocol (recommended by upstream docs)
alias telegram='nchat -d ~/.config/nchat'
alias signal='nchat -d ~/.config/nchat-signal'
