# Shared aliases — sourced by both zsh and bash

# Modern CLI replacements
alias l='eza -lhga --icons --group-directories-first'
alias ls='eza --icons --group-directories-first'
alias tree='eza --tree --icons'
alias cat='batcat --plain'
alias grep='grep --color=auto'

# Python
alias python='python3'
alias pip='pip3'
alias venv='source venv/bin/activate'

# File manager
y() {
	local tmp="$(mktemp -t "yazi-cwd.XXXXXX")" cwd
	yazi "$@" --cwd-file="$tmp"
	if cwd="$(command cat -- "$tmp")" && [ -n "$cwd" ] && [ "$cwd" != "$PWD" ]; then
		builtin cd -- "$cwd"
	fi
	rm -f -- "$tmp"
}

# Claude Code / Copilot CLI
alias claude='claude --allow-dangerously-skip-permissions'
# Make Copilot CLI pick up ~/.claude/CLAUDE.md (user prefs, style, Context7 rule)
export COPILOT_CUSTOM_INSTRUCTIONS_DIRS="$HOME/.claude"
