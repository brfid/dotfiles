[Unit]
Description=Tune ondemand CPU frequency governor on boot
After=cpufrequtils.service
Wants=cpufrequtils.service

[Service]
Type=oneshot
ExecStart=/bin/sh -c 'echo 20 > /sys/devices/system/cpu/cpufreq/ondemand/up_threshold; echo 100 > /sys/devices/system/cpu/cpufreq/ondemand/sampling_down_factor; echo 1 > /sys/devices/system/cpu/cpufreq/ondemand/ignore_nice_load'
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
