#!/usr/bin/env bash
# Global pre-commit hook: scan staged changes for secrets and PII.
# Installed via dotfiles — git config --global core.hooksPath points here.
set -euo pipefail

if ! command -v gitleaks &>/dev/null; then
    echo "ERROR: gitleaks not found — refusing commit without secret scan" >&2
    exit 1
fi

# Use repo-local .gitleaks.toml if present, otherwise the one next to this hook.
config=()
if [ -f ".gitleaks.toml" ]; then
    config=(--config .gitleaks.toml)
else
    hook_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    dotfiles_config="$(cd "$hook_dir/.." && pwd)/.gitleaks.toml"
    if [ -f "$dotfiles_config" ]; then
        config=(--config "$dotfiles_config")
    else
        echo "ERROR: no gitleaks config found — refusing commit without PII rules" >&2
        exit 1
    fi
fi

gitleaks protect --staged --redact --verbose --exit-code 1 "${config[@]}"

# Local identifier blocklist — patterns live outside the repo, never committed.
blocklist="$HOME/.config/git/blocklist"
if [ -f "$blocklist" ]; then
    diff=$(git diff --cached --unified=0)
    while IFS= read -r pattern || [ -n "$pattern" ]; do
        [[ "$pattern" =~ ^[[:space:]]*#|^[[:space:]]*$ ]] && continue
        if printf '%s' "$diff" | grep -qE "^\+.*${pattern}"; then
            echo "ERROR: commit blocked by local policy" >&2
            exit 1
        fi
    done < "$blocklist"
fi
