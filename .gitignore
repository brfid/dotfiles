# Secret material in any form
shell/env
*.secret
*.secrets
.secrets
.env
.env.*
*.key
*.pem

# shell/editor history
.bash_history
.lesshst

# python/cache
__pycache__/
*.pyc
.pytest_cache/

# uv (dev tooling only — repo is not a published package)
.venv/
uv.lock

