*.db
*.sqlite
*.sqlite-shm
*.sqlite-wal
*.log
logs/
sessions/
cache/
history.jsonl

# tmux plugin manager (installed at runtime)
tmux/.tmux/plugins/

# OS/editor
.DS_Store

# IDE
.vscode/
.idea/

# Local artifacts
/.superpowers/
/plans/
/.local-archives/

