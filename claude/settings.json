{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "auto",
    "deny": [
      "Bash(rm -rf *)",
      "Bash(*rm -rf*)",
      "Bash(rm -r /*)",
      "Bash(mkfs *)",
      "Bash(dd if=*of=/dev/*)",
      "Bash(*> /dev/sd*)",
      "Bash(chmod -R 777*)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)"
    ],
    "allow": [
      "Read(*)",
      "Glob(*)",
      "Grep(*)",
      "Bash(git log*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git branch*)",
      "Bash(ls *)",
      "Bash(which *)",
      "Bash(python3 -c *)",
      "Bash(pip list*)",
      "Write(~/dev/**)",
      "Edit(~/dev/**)",
      "Write(~/src/**)",
      "Edit(~/src/**)",
      "Write(~/.claude/**)",
      "Edit(~/.claude/**)",
      "mcp__context7__resolve-library-id(*)",
      "mcp__context7__query-docs(*)"
    ]
  },
  "env": {
    "CLAUDE_CODE_SUBAGENT_MODEL": "sonnet"
  },
  "model": "opus",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$CLAUDE_FILE_PATHS\" | grep -q '\\.py$'; then black --quiet $CLAUDE_FILE_PATHS 2>/dev/null; fi"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "jean-claude@local": true
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high"
}
