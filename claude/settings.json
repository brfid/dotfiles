{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_SUBAGENT_MODEL": "sonnet"
  },
  "permissions": {
    "allow": [
      "Read(*)",
      "Glob(*)",
      "Grep(*)",
      "WebFetch(*)",
      "WebSearch(*)",
      "Bash(git log*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git branch*)",
      "Bash(ls*)",
      "Bash(find *)",
      "Bash(locate *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(file *)",
      "Bash(stat *)",
      "Bash(wc *)",
      "Bash(which *)",
      "Bash(ps *)",
      "Bash(df *)",
      "Bash(du *)",
      "Bash(free*)",
      "Bash(uname*)",
      "Bash(hostname*)",
      "Bash(uptime*)",
      "Bash(id*)",
      "Bash(env*)",
      "Bash(printenv*)",
      "Bash(systemctl status*)",
      "Bash(systemctl list*)",
      "Bash(journalctl*)",
      "Bash(ip *)",
      "Bash(ss *)",
      "Bash(ping *)",
      "Bash(lsusb*)",
      "Bash(lsblk*)",
      "Bash(vcgencmd *)",
      "Bash(python3 -c *)",
      "Bash(pip list*)",
      "Write(~/**)",
      "Edit(~/**)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(*rm -rf*)",
      "Bash(rm -r /*)",
      "Bash(mkfs *)",
      "Bash(dd if=*of=/dev/*)",
      "Bash(*> /dev/sd*)",
      "Bash(chmod -R 777*)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)"
    ],
    "defaultMode": "acceptEdits"
  },
  "model": "opus[1m]",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$CLAUDE_FILE_PATHS\" | grep -q '\\.py$'; then black --quiet $CLAUDE_FILE_PATHS 2>/dev/null; fi"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "jean-claude@local": true
  },
  "extraKnownMarketplaces": {
    "local": {
      "source": {
        "source": "directory",
        "path": "/home/whf/src/dotfiles/claude/plugins"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "skipDangerousModePermissionPrompt": true
}
