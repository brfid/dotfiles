# Leopold FC660MBT (Bluetooth via Logitech receiver 046D:B023)
#
# Layout: Caps Lock ↔ Left Ctrl swap
# Mirrors the FC660MBT DIP switch 3 behaviour and the previous
# setxkbmap -option ctrl:swapcaps in x11/xprofile.
#
# NOTE: This matches the Logitech receiver, not the Leopold directly.
# Any keyboard on this receiver gets the remap.
#
# HID usage codes (0x700XX): 39=CapsLock, e0=LCtrl
# Bus 0005 = Bluetooth.

evdev:input:b0005v046Dp*
 KEYBOARD_KEY_70039=leftctrl
 KEYBOARD_KEY_700e0=capslock
