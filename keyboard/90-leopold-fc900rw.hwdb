# Leopold FC900RW (USB, Cypress HID 04B4:0510)
#
# Layout:
#   Caps Lock  → Left Ctrl
#   Left Ctrl  → Left Ctrl  (unchanged)
#   Right Ctrl → Caps Lock
#
# HID usage codes (0x700XX): 39=CapsLock, e0=LCtrl, e4=RCtrl
# Target values are Linux input key names (lowercase, no KEY_ prefix).

evdev:input:b0003v04B4p0510*
 KEYBOARD_KEY_70039=leftctrl
 KEYBOARD_KEY_700e4=capslock
